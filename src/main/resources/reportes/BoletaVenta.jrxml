<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BoletaVenta" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	
	<parameter name="p_nro_boleta" class="java.lang.String"/>
	<parameter name="p_paciente" class="java.lang.String"/>
	<parameter name="p_dni" class="java.lang.String"/>
	<parameter name="p_tratamiento" class="java.lang.String"/>
	<parameter name="p_total" class="java.lang.Double"/>
	<parameter name="p_logo" class="java.io.InputStream"/>

	<title>
		<band height="90">
			<image>
				<reportElement x="0" y="0" width="85" height="50"/>
				<imageExpression><![CDATA[$P{p_logo}]]></imageExpression>
			</image>

			<staticText>
				<reportElement x="100" y="0" width="350" height="25"/>
				<textElement>
					<font size="18" isBold="true"/>
				</textElement>
				<text><![CDATA[Centro Quiropráctico McLellan]]></text>
			</staticText>
			<staticText>
				<reportElement x="100" y="25" width="350" height="20"/>
				<text><![CDATA[RUC: 20555112233 | Dir: Av. Javier Prado Este 1234, Lima]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy HH:mm">
				<reportElement x="450" y="0" width="100" height="20"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<pageHeader>
		<band height="70">
			<rectangle>
				<reportElement x="0" y="0" width="555" height="30" backcolor="#D9EBFF"/>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="0" y="5" width="555" height="20"/>
				<textElement textAlignment="Center">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[BOLETA DE VENTA ELECTRÓNICA]]></text>
			</staticText>

			<staticText>
				<reportElement x="0" y="45" width="40" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[NRO:]]></text>
			</staticText>
			<textField>
				<reportElement x="40" y="45" width="100" height="20"/>
				<textFieldExpression><![CDATA[$P{p_nro_boleta}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="200" y="45" width="70" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[PACIENTE:]]></text>
			</staticText>
			<textField>
				<reportElement x="270" y="45" width="280" height="20"/>
				<textFieldExpression><![CDATA[$P{p_paciente} + " (" + $P{p_dni} + ")"]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>

	<columnHeader>
		<band height="30">
			<staticText>
				<reportElement x="0" y="10" width="350" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Descripción del Servicio]]></text>
			</staticText>
			<staticText>
				<reportElement x="450" y="10" width="100" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Total]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="30">
			<textField>
				<reportElement x="0" y="5" width="350" height="20"/>
				<textFieldExpression><![CDATA[$P{p_tratamiento}]]></textFieldExpression>
			</textField>
			<textField pattern="S/ #,##0.00">
				<reportElement x="450" y="5" width="100" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$P{p_total}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<summary>
		<band height="50">
			<line>
				<reportElement x="350" y="5" width="205" height="1"/>
			</line>
			<staticText>
				<reportElement x="350" y="10" width="100" height="25"/>
				<textElement verticalAlignment="Middle">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[TOTAL A PAGAR:]]></text>
			</staticText>
			<textField pattern="S/ #,##0.00">
				<reportElement x="450" y="10" width="100" height="25"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{p_total}]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>